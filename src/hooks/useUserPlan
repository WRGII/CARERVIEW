// src/hooks/useUserPlan.ts
import { useQuery } from '@tanstack/react-query'
import { supabase } from '../lib/supabaseClient'
import { useAuth } from './useAuth'

export type PlanId = 'primary_weekly' | 'occasional_monthly' | 'free'

export type UserPlan = {
  user_id: string
  plan_id: PlanId | null
  status: 'active' | 'past_due' | 'canceled' | 'trialing' | 'incomplete' | null
  current_period_start: string | null
  current_period_end: string | null
}

/**
 * Reads the user's current subscription info from app.v_user_plan.
 * Auth-gated: only runs once auth is loaded and we have a user id.
 */
export function useUserPlan() {
  const { user, loading } = useAuth()

  return useQuery({
    queryKey: ['user-plan', user?.id],
    enabled: !loading && !!user?.id,
    queryFn: async (): Promise<UserPlan | null> => {
      if (!user?.id) return null
      const { data, error } = await supabase
        .schema('app')
        .from('v_user_plan')
        .select(
          'user_id, plan_id, status, current_period_start, current_period_end'
        )
        .eq('user_id', user.id)
        .maybeSingle()

      if (error) {
        throw new Error(error.message)
      }
      return (data as UserPlan) ?? null
    },
    staleTime: 60_000,
  })
}
