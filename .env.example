# =============================================================================
# CarerView Environment Variables
# =============================================================================
#
# VITE_* variables are used by the frontend (exposed to the browser).
# All other variables are used by Supabase Edge Functions (server-side only).
#
# Supabase auto-provides SUPABASE_URL, SUPABASE_ANON_KEY, and
# SUPABASE_SERVICE_ROLE_KEY inside Edge Functions — you only need to set
# them manually if running functions locally via the Supabase CLI.
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
# Found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# Edge Functions — Supabase (auto-provided in hosted environment)
# ---------------------------------------------------------------------------
# Only set these if running Edge Functions locally with `supabase functions serve`
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# Edge Functions — Stripe
# ---------------------------------------------------------------------------
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...

# Found in: Stripe Dashboard → Developers → Webhooks → Signing secret
# The webhook function accepts either a single secret or a comma-separated
# list (STRIPE_WEBHOOK_SECRETS) for key rotation.
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_WEBHOOK_SECRETS=whsec_old...,whsec_new...

# ---------------------------------------------------------------------------
# Edge Functions — Site URL
# ---------------------------------------------------------------------------
# Used for CORS origin restriction and redirect URLs.
# If unset, Edge Functions fall back to wildcard (*) CORS.
PUBLIC_SITE_URL=https://carerview.com

# ---------------------------------------------------------------------------
# Edge Functions — Resend (transactional email)
# ---------------------------------------------------------------------------
# Found in: Resend Dashboard → API Keys
# The sending domain (carerview.com) must be verified in Resend before use.
#
# This single key serves two purposes:
#   1. Edge function HTTP API calls (send-invite-email, notify-*, etc.)
#   2. Local SMTP relay — config.toml references env(RESEND_API_KEY) as the
#      SMTP password for smtp.resend.com:465 (user: resend)
#
# For production hosted Supabase, enter this same key value as the SMTP
# password in: Dashboard → Authentication → Settings → SMTP (Pro plan).
RESEND_API_KEY=re_...

# The verified sender address shown in the From field.
EMAIL_FROM=CarerView <noreply@carerview.com>

# Reply-to address for all outbound emails.
EMAIL_REPLY_TO=support@carerview.com
